<Window x:Class="SystemFileKiller.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:SystemFileKiller.GUI.Views"
        Title="System File Killer"
        Icon="/Resources/sfk.ico"
        Height="780" Width="1280" MinHeight="540" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ShowInTaskbar="True"
        ShowActivated="True"
        Background="{DynamicResource Bg}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Theme tray button styles -->
        <Style x:Key="TrayBtn" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" CornerRadius="11"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TrayBtnPaper" TargetType="Button" BasedOn="{StaticResource TrayBtn}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F6F3EC" Offset="0"/>
                        <GradientStop Color="#F6F3EC" Offset="0.5"/>
                        <GradientStop Color="#1A1814" Offset="0.5"/>
                        <GradientStop Color="#1A1814" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DensityBtn" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="{DynamicResource Panel2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rail row template — used by each nav button -->
        <Style x:Key="RailItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg2}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource Panel}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource Panel}"/>
                                <Setter TargetName="B" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── TITLE BAR ─── -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{DynamicResource TitleBg}"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="14" Height="14" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Path Data="M0,0 L14,14 M14,0 L0,14"
                          Stroke="{DynamicResource Accent}" StrokeThickness="2"
                          SnapsToDevicePixels="True"/>
                </Grid>
                <TextBlock Grid.Column="1" Margin="10,0,14,0" VerticalAlignment="Center"
                           Text="SYSTEM·FILE·KILLER"
                           FontFamily="{StaticResource FontMono}" FontSize="11"
                           Foreground="{DynamicResource Fg2}"/>
                <TextBlock Grid.Column="2" VerticalAlignment="Center"
                           Text="v0.9.4 · build fc6e9ff · main"
                           FontFamily="{StaticResource FontMono}" FontSize="10"
                           Foreground="{DynamicResource Fg4}"/>

                <Border Grid.Column="3" Style="{StaticResource Pill}" Margin="6,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="DotAdmin" Width="6" Height="6" Fill="{DynamicResource Fg4}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PillAdminText" Text="ADMIN"
                                   FontFamily="{StaticResource FontMono}" FontSize="10"
                                   Foreground="{DynamicResource Fg2}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource Pill}" Margin="6,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="DotPipe" Width="6" Height="6" Fill="{DynamicResource Fg4}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PillPipeText" Text="PIPE"
                                   FontFamily="{StaticResource FontMono}" FontSize="10"
                                   Foreground="{DynamicResource Fg2}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="5" Style="{StaticResource Pill}" Margin="6,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="DotDebug" Width="6" Height="6" Fill="{DynamicResource Fg4}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SeDebug"
                                   FontFamily="{StaticResource FontMono}" FontSize="10"
                                   Foreground="{DynamicResource Fg2}"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="6" Margin="14,0,8,0" VerticalAlignment="Center"
                           x:Name="ClockText"
                           FontFamily="{StaticResource FontMono}" FontSize="11"
                           Foreground="{DynamicResource Fg3}"/>

                <StackPanel Grid.Column="7" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource TitlebarBtn}" Click="Min_Click" ToolTip="Minimize">
                        <Path Data="M3,8 L13,8" Stroke="{DynamicResource Fg3}" StrokeThickness="1.5" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource TitlebarBtn}" Click="Max_Click" ToolTip="Maximize">
                        <Path Data="M3.5,3.5 H12.5 V12.5 H3.5 Z" Stroke="{DynamicResource Fg3}" StrokeThickness="1.5" Fill="Transparent" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource TitlebarBtnClose}" Click="Close_Click" ToolTip="Close">
                        <Path Data="M3.5,3.5 L12.5,12.5 M12.5,3.5 L3.5,12.5" Stroke="{DynamicResource Fg3}" StrokeThickness="1.5" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── LEFT RAIL ─── -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource RailBg}"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">

                <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="18,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource DimMonoSmall}">
                            <Run Text="OPERATOR · "/><Run Foreground="{DynamicResource Fg2}" Text="JAY"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource DimMonoSmall}">
                            <Run Text="SHELL · "/><Run Foreground="{DynamicResource Fg2}" Text="WPF"/><Run Text=" + "/><Run Foreground="{DynamicResource Fg2}" Text="Core"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource DimMonoSmall}" Margin="0,8,0,0"
                                   Text="F5 refresh · Ctrl+K palette"/>
                    </StackPanel>
                </Border>

                <StackPanel>
                    <TextBlock Margin="18,14,18,6" Style="{StaticResource EyebrowText}" Text="SURFACES"/>

                    <!-- Each rail item is a button. Tag is set to "active" or empty by code-behind to drive the visual state. -->
                    <Button x:Name="NavDashboard" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="dashboard">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M2,7.5 L8,2 L14,7.5 V14 H2 Z M6,14 V9.5 H10 V14"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Overview" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavProcesses" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="processes">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M3.5,3.5 H12.5 V12.5 H3.5 Z M6,6 H10 V10 H6 Z M3.5,6 H2.5 M3.5,10 H2.5 M13.5,6 H12.5 M13.5,10 H12.5 M6,3.5 V2.5 M10,3.5 V2.5 M6,13.5 V12.5 M10,13.5 V12.5"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Processes" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Grid.Column="2" x:Name="NavProcessesCount" Text="—"
                                       FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="{DynamicResource Fg4}" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavServices" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="services">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M8,6 A2,2 0 1 0 8,10 A2,2 0 1 0 8,6 M8,1.5 V3.5 M8,12.5 V14.5 M1.5,8 H3.5 M12.5,8 H14.5 M3.5,3.5 L4.9,4.9 M11.1,11.1 L12.5,12.5 M3.5,12.5 L4.9,11.1 M11.1,4.9 L12.5,3.5"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Services" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Grid.Column="2" x:Name="NavServicesCount" Text="—"
                                       FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="{DynamicResource Fg4}" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavFiles" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="files">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M4,2 H9 L12,5 V14 H4 Z M9,2 V5 H12"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Files" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavRegistry" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="registry">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M3,3.5 A5,1.5 0 1 0 13,3.5 A5,1.5 0 1 0 3,3.5 M3,3.5 V12.5 C3,13.3 5.2,14 8,14 C10.8,14 13,13.3 13,12.5 V3.5 M3,8 C3,8.8 5.2,9.5 8,9.5 C10.8,9.5 13,8.8 13,8"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Registry" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="NavRegistryBadge" Visibility="Collapsed" Style="{StaticResource Badge}" Margin="0,0,4,0"
                                        Background="{DynamicResource AccentGlow}" BorderBrush="{DynamicResource Accent}">
                                    <TextBlock x:Name="NavRegistryBadgeText" Text="0" Style="{StaticResource BadgeText}" Foreground="{DynamicResource Accent2}"/>
                                </Border>
                                <TextBlock x:Name="NavRegistryCount" Text="—"
                                           FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="{DynamicResource Fg4}"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="NavAnalyze" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="analyze">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M2,5 V3 H4 M14,5 V3 H12 M2,11 V13 H4 M14,11 V13 H12 M3,8 H13 M8,8 m-0.5,0 a0.5,0.5 0 1 0 1,0 a0.5,0.5 0 1 0 -1,0"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Analyze" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <TextBlock Margin="18,18,18,6" Style="{StaticResource EyebrowText}" Text="ORCHESTRATION"/>

                    <Button x:Name="NavBatch" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="batch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M2,3 H8 M2,6.5 H10 M2,10 H7 M2,13.5 H11 M12,3 L14,3 M12,6.5 L14,6.5 M12,10 L14,10 M12,13.5 L14,13.5"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Batch Builder" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Grid.Column="2" x:Name="NavBatchCount" Text=""
                                       FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="{DynamicResource Fg4}" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavNuke" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="nuke">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M8,1.5 L4,5 V8 L1.5,9 V11 H4.5 V13 H6 V14.5 H10 V13 H11.5 V11 H14.5 V9 L12,8 V5 Z M6,5.5 H10 M7,8 H9"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Nuke" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <TextBlock Margin="18,18,18,6" Style="{StaticResource EyebrowText}" Text="FORENSIC"/>

                    <Button x:Name="NavTasks" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="tasks">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M3,3 H13 V13 H3 Z M3,6 H13 M5,9 H8 M5,11 H10"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Tasks" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavQuarantine" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="quarantine">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M2,4 H14 V6 H2 Z M3,6 V13 H13 V6 M6,9 H10"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Quarantine" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavTools" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="tools">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M3,12 L8,7 M8,7 L11,4 L13,6 L10,9 Z M3,12 L4,13 L5,12 M5,7 L8,4 M2,2 L4,4"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Analysis Tools" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavNetwork" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="network">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M8,8 m-6,0 a6,6 0 1 0 12,0 a6,6 0 1 0 -12,0 M2,8 H14 M8,2 C5,5 5,11 8,14 M8,2 C11,5 11,11 8,14"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Network" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>

                    <Button x:Name="NavPersist" Style="{StaticResource RailItem}" Click="Nav_Click" CommandParameter="persistence">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="M8,2 L13,5 V11 L8,14 L3,11 V5 Z M8,2 V14 M3,5 L13,11 M3,11 L13,5"
                                  Stroke="{DynamicResource Fg3}" StrokeThickness="1.2" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Persistence" FontFamily="{StaticResource FontUi}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ─── MAIN CONTENT ─── -->
        <Grid Grid.Row="1" Grid.Column="1">
            <views:DashboardView x:Name="ViewDashboard" Visibility="Collapsed"/>
            <views:ProcessesView x:Name="ViewProcesses" Visibility="Visible"/>
            <views:ServicesView  x:Name="ViewServices"  Visibility="Collapsed"/>
            <views:FilesView     x:Name="ViewFiles"     Visibility="Collapsed"/>
            <views:RegistryView  x:Name="ViewRegistry"  Visibility="Collapsed"/>
            <views:AnalyzeView   x:Name="ViewAnalyze"   Visibility="Collapsed"/>
            <views:BatchView     x:Name="ViewBatch"     Visibility="Collapsed"/>
            <views:NukeView      x:Name="ViewNuke"      Visibility="Collapsed"/>
            <views:TasksView     x:Name="ViewTasks"     Visibility="Collapsed"/>
            <views:QuarantineView x:Name="ViewQuarantine" Visibility="Collapsed"/>
            <views:AnalysisToolsView x:Name="ViewTools" Visibility="Collapsed"/>
            <views:NetworkView   x:Name="ViewNetwork"   Visibility="Collapsed"/>
            <views:PersistenceView x:Name="ViewPersist" Visibility="Collapsed"/>
        </Grid>

        <!-- ─── STATUS FOOTER ─── -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{DynamicResource TitleBg}"
                BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock Text="SCREEN" Foreground="{DynamicResource Fg4}" Margin="0,0,6,0"
                               FontFamily="{StaticResource FontMono}" FontSize="11"/>
                    <TextBlock x:Name="ScreenLabel" Text="PROCESSES" Foreground="{DynamicResource Fg2}"
                               FontFamily="{StaticResource FontMono}" FontSize="11"/>
                </StackPanel>
                <Border Grid.Column="1" BorderBrush="{DynamicResource Line}" BorderThickness="1,0,0,0" Padding="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="LAST" Foreground="{DynamicResource Fg4}" Margin="0,0,6,0"
                                   FontFamily="{StaticResource FontMono}" FontSize="11"/>
                        <TextBlock x:Name="StatusText" Text="Ready · session active" Foreground="{DynamicResource Fg2}"
                                   FontFamily="{StaticResource FontMono}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" BorderBrush="{DynamicResource Line}" BorderThickness="1,0,0,0" Padding="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="UTC" Foreground="{DynamicResource Fg4}" Margin="0,0,6,0"
                                   FontFamily="{StaticResource FontMono}" FontSize="11"/>
                        <TextBlock x:Name="ClockText2" Text="--:--:--" Foreground="{DynamicResource Fg3}"
                                   FontFamily="{StaticResource FontMono}" FontSize="11"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ─── FLOATING THEME TRAY (bottom-right) ─── -->
        <Border Grid.Row="1" Grid.Column="1"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,16,16"
                Background="{DynamicResource Panel}"
                BorderBrush="{DynamicResource Line}" BorderThickness="1"
                CornerRadius="6" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ACCENT" Foreground="{DynamicResource Fg4}" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontMono}" FontSize="10" Margin="4,0,8,0"/>
                <Button x:Name="SwatchRed"   Style="{StaticResource TrayBtn}" Click="Accent_Click" CommandParameter="default"
                        Background="#DA4339" ToolTip="Red"/>
                <Button x:Name="SwatchAmber" Style="{StaticResource TrayBtn}" Click="Accent_Click" CommandParameter="amber"
                        Background="#E1B05E" ToolTip="Amber"/>
                <Button x:Name="SwatchBlue"  Style="{StaticResource TrayBtn}" Click="Accent_Click" CommandParameter="blue"
                        Background="#5BA3DD" ToolTip="Blue"/>
                <Button x:Name="SwatchGreen" Style="{StaticResource TrayBtn}" Click="Accent_Click" CommandParameter="green"
                        Background="#5BD68D" ToolTip="Green"/>
                <Border Width="1" Background="{DynamicResource Line2}" Margin="6,3"/>
                <TextBlock Text="SURFACE" Foreground="{DynamicResource Fg4}" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontMono}" FontSize="10" Margin="4,0,8,0"/>
                <Button x:Name="SwatchDark"  Style="{StaticResource TrayBtn}" Click="Surface_Click" CommandParameter="dark"
                        Background="#0A0C10" ToolTip="Dark"/>
                <Button x:Name="SwatchPaper" Style="{StaticResource TrayBtnPaper}" Click="Surface_Click" CommandParameter="paper" ToolTip="Paper"/>
                <Border Width="1" Background="{DynamicResource Line2}" Margin="6,3"/>
                <TextBlock Text="DENSITY" Foreground="{DynamicResource Fg4}" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontMono}" FontSize="10" Margin="4,0,8,0"/>
                <Button x:Name="DensityCompact" Style="{StaticResource DensityBtn}" Click="Density_Click" CommandParameter="compact" ToolTip="Compact">
                    <StackPanel>
                        <Border Height="1.5" Background="{DynamicResource Fg3}" Margin="0,1"/>
                        <Border Height="1.5" Background="{DynamicResource Fg3}" Margin="0,1"/>
                        <Border Height="1.5" Background="{DynamicResource Fg3}" Margin="0,1"/>
                        <Border Height="1.5" Background="{DynamicResource Fg3}" Margin="0,1"/>
                    </StackPanel>
                </Button>
                <Button x:Name="DensityCozy" Style="{StaticResource DensityBtn}" Click="Density_Click" CommandParameter="cozy" ToolTip="Cozy">
                    <StackPanel>
                        <Border Height="2" Background="{DynamicResource Fg3}" Margin="0,2"/>
                        <Border Height="2" Background="{DynamicResource Fg3}" Margin="0,2"/>
                        <Border Height="2" Background="{DynamicResource Fg3}" Margin="0,2"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>

<UserControl x:Class="SystemFileKiller.GUI.Views.FilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ScreenHeadBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource EyebrowText}" Text="MODE · 03"/>
                <TextBlock Style="{StaticResource ScreenTitle}" Text="Files"/>
                <TextBlock Foreground="{DynamicResource Fg3}" FontSize="12" Margin="0,4,0,0"
                           Text="Force-delete locked files · close foreign handles · schedule reboot delete"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="22,14,22,16">
            <StackPanel>
                <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,0,0,8" Text="TARGET PATH"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line2}" BorderThickness="1" CornerRadius="2" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▸" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="PathBox" BorderThickness="0" Background="Transparent" MinWidth="200"/>
                        </StackPanel>
                    </Border>
                    <Button Grid.Column="1" Style="{StaticResource Btn}" Content="File…" Click="BrowseFile_Click" Margin="8,0,0,0"/>
                    <Button Grid.Column="2" Style="{StaticResource Btn}" Content="Folder…" Click="BrowseFolder_Click" Margin="8,0,0,0"/>
                </Grid>
                <WrapPanel Margin="0,12,0,0">
                    <Button Style="{StaticResource Btn}"      Content="Unlock handles" Click="Unlock_Click" Margin="0,0,8,8"/>
                    <Button Style="{StaticResource BtnDanger}" Content="Force delete file" Click="Delete_Click" Margin="0,0,8,8"/>
                    <Button Style="{StaticResource BtnDanger}" Content="Wipe directory" Click="DeleteDir_Click" Margin="0,0,8,8"/>
                    <Button Style="{StaticResource Btn}"      Content="Reboot delete" Click="RebootDelete_Click" Margin="0,0,8,8"/>
                    <Button Style="{StaticResource Btn}"      Content="Probe locks" Click="Probe_Click" Margin="0,0,8,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="22,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Style="{StaticResource PanelSectionTitle}" Text="CONSOLE"/>
                <Border Grid.Row="1" Style="{StaticResource ConsoleBorder}">
                    <ScrollViewer x:Name="ConsoleScroll" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ConsoleList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,2">
                                        <Run Text="{Binding Timestamp, StringFormat='[{0:HH:mm:ss}]'}" Foreground="{DynamicResource Fg4}"/>
                                        <Run Text="{Binding Kind}" Foreground="{Binding KindBrush}"/>
                                        <Run Text="{Binding Text}" Foreground="{DynamicResource Fg2}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource DetailPaneBorder}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="16,14,16,12">
                        <StackPanel>
                            <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,0,0,6" Text="LAST OPERATION"/>
                            <TextBlock x:Name="LastOpTarget" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg3}" TextWrapping="Wrap" Text="—"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Padding="16,14">
                        <StackPanel>
                            <ItemsControl x:Name="StagesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Number}" FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="{DynamicResource Fg4}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg2}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Result}" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{Binding StatusBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,16,0,8" Text="LOCKING PROCESSES"/>
                            <ItemsControl x:Name="LockersList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Pid}" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg2}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource Fg4}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="SystemFileKiller.GUI.Views.ProcessesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Screen head -->
        <Border Grid.Row="0" Style="{StaticResource ScreenHeadBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource EyebrowText}" Text="MODE · 01"/>
                    <TextBlock Style="{StaticResource ScreenTitle}" Text="Processes"/>
                    <TextBlock x:Name="SubText" Foreground="{DynamicResource Fg3}" FontSize="12" Margin="0,4,0,0"
                               Text="0 listed · 0 selected · SeDebugPrivilege —"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line2}" BorderThickness="1" CornerRadius="2"
                            Padding="8,3" Margin="0,0,8,0" Width="280">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="/" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="FilterBox" BorderThickness="0" Background="Transparent" Width="240"
                                     TextChanged="Filter_TextChanged"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource Btn}" Click="Refresh_Click" Content="Refresh"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stat strip -->
        <Border Grid.Row="1" Style="{StaticResource StatStripBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0" Padding="16,10">
                    <StackPanel>
                        <TextBlock Text="TOTAL PROCESSES" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" FontSize="10"/>
                        <TextBlock x:Name="StatTotal" Text="0" Foreground="{DynamicResource Fg}" FontFamily="{StaticResource FontMono}" FontSize="18" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0" Padding="16,10">
                    <StackPanel>
                        <TextBlock Text="PRIVILEGE" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" FontSize="10"/>
                        <TextBlock x:Name="StatPriv" Text="—" Foreground="{DynamicResource Green}" FontFamily="{StaticResource FontMono}" FontSize="18" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0" Padding="16,10">
                    <StackPanel>
                        <TextBlock Text="HELPER PIPE" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" FontSize="10"/>
                        <TextBlock x:Name="StatPipe" Text="—" Foreground="{DynamicResource Fg}" FontFamily="{StaticResource FontMono}" FontSize="18" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Padding="16,10">
                    <StackPanel>
                        <TextBlock Text="MEMORY · USED / INSTALLED" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" FontSize="10"/>
                        <TextBlock x:Name="StatMem" Text="—" Foreground="{DynamicResource Fg}" FontFamily="{StaticResource FontMono}" FontSize="18" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Split: table + detail -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ToolbarBorder}">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource BtnDanger}" Content="Force kill" Click="Kill_Click" x:Name="BtnKill" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource BtnDanger}" Content="Kill tree" Click="KillTree_Click" x:Name="BtnKillTree" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource Btn}" Content="Open location" Click="OpenLocation_Click" x:Name="BtnOpen" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource Btn}" Content="Copy PID" Click="CopyPid_Click" x:Name="BtnCopy"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <CheckBox x:Name="ChkKillTree" Content="killTree" Margin="12,0"/>
                            <CheckBox x:Name="ChkUseElevation" Content="useElevation" Margin="0,0,8,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1" x:Name="Grid" SelectionMode="Extended"
                          SelectionChanged="Grid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Fg2}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="220">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Fg4}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="MEM" Binding="{Binding MemoryDisplay}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Fg2}"/>
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Detail pane -->
            <Border Grid.Column="1" Style="{StaticResource DetailPaneBorder}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="16,14,16,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border Style="{StaticResource Badge}" Background="{DynamicResource AccentGlow}" BorderBrush="{DynamicResource Accent}">
                                    <TextBlock Text="TARGET" Style="{StaticResource BadgeText}" Foreground="{DynamicResource Accent2}"/>
                                </Border>
                                <TextBlock x:Name="TargetPidText" Text="—" Foreground="{DynamicResource Fg4}"
                                           FontFamily="{StaticResource FontMono}" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="TargetNameText" Text="no single selection"
                                       FontFamily="{StaticResource FontMono}" FontSize="14" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Padding="16,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="PID" Style="{StaticResource DimMonoSmall}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetPid" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="MEMORY" Style="{StaticResource DimMonoSmall}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetMem" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="PATH" Style="{StaticResource DimMonoSmall}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetPath" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="DESC" Style="{StaticResource DimMonoSmall}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetDesc" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                            </Grid>

                            <TextBlock Style="{StaticResource PanelSectionTitle}" Text="ESCALATION LADDER"/>
                            <ItemsControl x:Name="TraceList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3,0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Number}" FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="{DynamicResource Fg4}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg2}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Result}" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{Binding StatusBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,16,0,8" Text="HINT"/>
                            <TextBlock x:Name="HintText" Foreground="{DynamicResource Fg3}" FontSize="12" TextWrapping="Wrap"
                                       Text="Standard user-mode process. Stage 1 should resolve immediately."/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

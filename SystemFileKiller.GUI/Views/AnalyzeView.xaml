<UserControl x:Class="SystemFileKiller.GUI.Views.AnalyzeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ScreenHeadBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource EyebrowText}" Text="MODE · 05"/>
                    <TextBlock Style="{StaticResource ScreenTitle}" Text="Analyze binary"/>
                    <TextBlock Foreground="{DynamicResource Fg3}" FontSize="12" Margin="0,4,0,0"
                               Text="Hash · signature · version · header preview · local heuristics"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource Btn}" Content="Open file…" Click="Open_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource BtnPrimary}" Content="Re-analyze" Click="Reanalyze_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Subject panel -->
        <Border Grid.Row="1" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="22,14">
            <StackPanel>
                <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,0,0,6" Text="SUBJECT"/>
                <TextBlock x:Name="SubjectPath" FontFamily="{StaticResource FontMono}" FontSize="13" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"
                           Text="(no file selected)"/>
                <StackPanel x:Name="BadgeRow" Orientation="Horizontal" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="2" Padding="14" Margin="0,0,8,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PanelSectionTitle}" Text="IDENTITY"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="SIZE" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetSize" Text="—" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SHA-256" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetSha" Text="—" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="MD5" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetMd5" Text="—" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="CREATED" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetCreated" Text="—" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="MODIFIED" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DetModified" Text="—" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="2" Padding="14" Margin="8,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PanelSectionTitle}" Text="SIGNATURE"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="SIGNED" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetSigned" Text="—" FontFamily="{StaticResource FontMono}" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SIGNER" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetSigner" Text="—" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="PRODUCT" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetProduct" Text="—" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="VERSION" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetVersion" Text="—" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="DESCRIPTION" Style="{StaticResource DimMonoSmall}" Margin="0,2"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DetDescription" Text="—" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Local heuristics -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="2" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PanelSectionTitle}" Text="LOCAL HEURISTICS"/>
                        <ItemsControl x:Name="HeuristicsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Check}" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Result}" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{Binding Brush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Hex preview -->
                <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="2" Padding="14" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PanelSectionTitle}" Text="HEADER PREVIEW · first 256 bytes"/>
                        <Border Background="{DynamicResource ConsoleBg}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="2" Padding="12,10">
                            <TextBlock x:Name="HexPreview" FontFamily="{StaticResource FontMono}" FontSize="10" Foreground="{DynamicResource Fg3}"
                                       LineHeight="16" Text="—"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Recommended action -->
                <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="2" Padding="14" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PanelSectionTitle}" Text="RECOMMENDED ACTION"/>
                        <TextBlock x:Name="PlaybookText" Foreground="{DynamicResource Fg2}" FontSize="12" TextWrapping="Wrap" LineHeight="18"
                                   Text="Open a binary to generate a playbook."/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>

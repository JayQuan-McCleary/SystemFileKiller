<UserControl x:Class="SystemFileKiller.GUI.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ScreenHeadBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource EyebrowText}" Text="MODE · 12"/>
                <TextBlock Style="{StaticResource ScreenTitle}" Text="Network"/>
                <TextBlock Foreground="{DynamicResource Fg3}" FontSize="12" Margin="0,4,0,0"
                           Text="Active TCPv4 connections with owning PID — netstat -ano as structured data. Watch for processes that shouldn't be talking to the internet."/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="22,12">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource Btn}" Content="Refresh" Click="Refresh_Click" Margin="0,0,8,0"/>
                <CheckBox x:Name="EstablishedOnly" Content="ESTABLISHED only" IsChecked="True" Foreground="{DynamicResource Fg2}" VerticalAlignment="Center" Margin="8,0,16,0"/>
                <TextBlock Text="Filter:" Foreground="{DynamicResource Fg3}" VerticalAlignment="Center" Margin="8,0,4,0"/>
                <TextBox x:Name="FilterBox" Width="200" Background="{DynamicResource Panel}" Foreground="{DynamicResource Fg2}" BorderBrush="{DynamicResource Line2}" Padding="6,3" VerticalAlignment="Center"/>
                <TextBlock x:Name="CountLabel" Text="—" Foreground="{DynamicResource Fg3}" FontFamily="{StaticResource FontMono}" FontSize="11" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="ConnGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg2}"
                  RowBackground="{DynamicResource Bg}" AlternatingRowBackground="{DynamicResource Bg2}"
                  BorderBrush="{DynamicResource Line}" GridLinesVisibility="None"
                  HeadersVisibility="Column" SelectionMode="Extended" Margin="22,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="70"/>
                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100"/>
                <DataGridTextColumn Header="Local" Binding="{Binding LocalEndpoint}" Width="180"/>
                <DataGridTextColumn Header="Remote" Binding="{Binding RemoteEndpoint}" Width="180"/>
                <DataGridTextColumn Header="PID" Binding="{Binding OwningPid}" Width="70"/>
                <DataGridTextColumn Header="Process" Binding="{Binding OwningProcessName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

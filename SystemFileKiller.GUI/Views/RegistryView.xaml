<UserControl x:Class="SystemFileKiller.GUI.Views.RegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ScreenHeadBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource EyebrowText}" Text="MODE · 04"/>
                    <TextBlock Style="{StaticResource ScreenTitle}" Text="Registry persistence"/>
                    <TextBlock x:Name="SubText" Foreground="{DynamicResource Fg3}" FontSize="12" Margin="0,4,0,0" Text="0 entries · 0 flagged suspicious"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Style="{StaticResource Btn}" Content="Scan all" Click="ScanAll_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnSuspicious" Style="{StaticResource Btn}" Content="Show suspicious only" Click="ToggleSuspicious_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource StatStripBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0" Padding="16,10">
                    <StackPanel>
                        <TextBlock Text="HKLM\Run" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" FontSize="10"/>
                        <TextBlock x:Name="StatHKLM" Text="0" Foreground="{DynamicResource Fg}" FontFamily="{StaticResource FontMono}" FontSize="18" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0" Padding="16,10">
                    <StackPanel>
                        <TextBlock Text="HKCU\Run" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" FontSize="10"/>
                        <TextBlock x:Name="StatHKCU" Text="0" Foreground="{DynamicResource Fg}" FontFamily="{StaticResource FontMono}" FontSize="18" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,1,0" Padding="16,10">
                    <StackPanel>
                        <TextBlock Text="WINLOGON HOOKS" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" FontSize="10"/>
                        <TextBlock x:Name="StatWinlogon" Text="0" Foreground="{DynamicResource Amber}" FontFamily="{StaticResource FontMono}" FontSize="18" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Padding="16,10">
                    <StackPanel>
                        <TextBlock Text="SUSPICIOUS" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" FontSize="10"/>
                        <TextBlock x:Name="StatSusp" Text="0" Foreground="{DynamicResource Accent2}" FontFamily="{StaticResource FontMono}" FontSize="18" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource ToolbarBorder}">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource BtnDanger}" Content="Remove selected" Click="RemoveSelected_Click" x:Name="BtnRemove" Margin="0,0,8,0"/>
                <Button Style="{StaticResource BtnDanger}" Content="Purge all suspicious" Click="PurgeSuspicious_Click" x:Name="BtnPurge"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" x:Name="Grid" SelectionMode="Extended"
                      SelectionChanged="Grid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="HIVE" Binding="{Binding Hive}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Blue}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="KEY" Binding="{Binding KeyPath}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Fg4}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="VALUE" Binding="{Binding ValueName}" Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="VERDICT" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Badge}" HorizontalAlignment="Left"
                                        Background="{Binding VerdictBg}" BorderBrush="{Binding VerdictBorder}">
                                    <TextBlock Text="{Binding VerdictLabel}" Style="{StaticResource BadgeText}" Foreground="{Binding VerdictFg}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Style="{StaticResource DetailPaneBorder}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="16,14,16,12">
                        <StackPanel>
                            <Border x:Name="DetVerdictBadge" Style="{StaticResource Badge}" HorizontalAlignment="Left" Margin="0,0,0,8"
                                    Background="Transparent" BorderBrush="{DynamicResource Line2}">
                                <TextBlock x:Name="DetVerdictText" Text="—" Style="{StaticResource BadgeText}" Foreground="{DynamicResource Fg3}"/>
                            </Border>
                            <TextBlock x:Name="DetValueName" FontFamily="{StaticResource FontMono}" FontSize="13" Text="no selection" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Padding="16,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="HIVE" Style="{StaticResource DimMonoSmall}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetHive" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="KEY" Style="{StaticResource DimMonoSmall}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetKey" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="NAME" Style="{StaticResource DimMonoSmall}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetName" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="VALUE" Style="{StaticResource DimMonoSmall}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetValue" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg}" TextWrapping="Wrap"/>
                            </Grid>
                            <Border x:Name="ReasonPanel" Visibility="Collapsed" Padding="10" Margin="0,8,0,0"
                                    Background="{DynamicResource AccentGlow}" BorderBrush="{DynamicResource AccentDim}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource PanelSectionTitle}" Foreground="{DynamicResource Accent2}" Text="REASON"/>
                                    <TextBlock x:Name="DetReason" Foreground="{DynamicResource Accent2}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

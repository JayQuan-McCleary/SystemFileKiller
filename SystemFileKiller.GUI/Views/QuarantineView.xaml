<UserControl x:Class="SystemFileKiller.GUI.Views.QuarantineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ScreenHeadBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource EyebrowText}" Text="MODE · 10"/>
                <TextBlock Style="{StaticResource ScreenTitle}" Text="Quarantine"/>
                <TextBlock Foreground="{DynamicResource Fg3}" FontSize="12" Margin="0,4,0,0"
                           Text="Reversible delete — zip the target into %ProgramData%\SFK\Quarantine\&lt;id&gt;\, remove the original. Restore re-extracts."/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="22,14,22,16">
            <StackPanel>
                <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,0,0,8" Text="QUARANTINE NEW PATH"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Line2}" BorderThickness="1" CornerRadius="2" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▸" Foreground="{DynamicResource Fg4}" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="PathBox" BorderThickness="0" Background="Transparent" MinWidth="200"/>
                        </StackPanel>
                    </Border>
                    <Button Grid.Column="1" Style="{StaticResource Btn}" Content="Browse…" Click="Browse_Click" Margin="8,0,0,0"/>
                    <Button Grid.Column="2" Style="{StaticResource BtnDanger}" Content="Quarantine" Click="Quarantine_Click" Margin="8,0,0,0"/>
                </Grid>
                <WrapPanel Margin="0,12,0,0">
                    <Button Style="{StaticResource Btn}" Content="Refresh List" Click="Refresh_Click" Margin="0,0,8,8"/>
                    <Button Style="{StaticResource Btn}" Content="Restore Selected" Click="Restore_Click" Margin="0,0,8,8"/>
                    <TextBlock Text="Purge older than (days):" Foreground="{DynamicResource Fg3}" VerticalAlignment="Center" Margin="16,0,6,8"/>
                    <TextBox x:Name="PurgeDaysBox" Text="0" Width="48" VerticalAlignment="Center" Margin="0,0,8,8" Background="{DynamicResource Panel}" Foreground="{DynamicResource Fg2}" BorderBrush="{DynamicResource Line2}"/>
                    <Button Style="{StaticResource BtnDanger}" Content="Purge" Click="Purge_Click" Margin="0,0,8,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="ItemsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg2}"
                  RowBackground="{DynamicResource Bg}" AlternatingRowBackground="{DynamicResource Bg2}"
                  BorderBrush="{DynamicResource Line}" GridLinesVisibility="None"
                  HeadersVisibility="Column" SelectionMode="Extended" Margin="22,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Quarantined" Binding="{Binding QuarantinedAt}" Width="170"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Kind}" Width="60"/>
                <DataGridTextColumn Header="Original Path" Binding="{Binding OriginalPath}" Width="*"/>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="100"/>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="220"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

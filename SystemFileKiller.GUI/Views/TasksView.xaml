<UserControl x:Class="SystemFileKiller.GUI.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ScreenHeadBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource EyebrowText}" Text="MODE · 09"/>
                <TextBlock Style="{StaticResource ScreenTitle}" Text="Scheduled Tasks"/>
                <TextBlock Foreground="{DynamicResource Fg3}" FontSize="12" Margin="0,4,0,0"
                           Text="Discover and remove Task Scheduler persistence — the second-most-common malware persistence vector after Run keys."/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="22,12">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="SuspiciousOnly" Content="suspicious only" Foreground="{DynamicResource Fg2}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Style="{StaticResource Btn}" Content="Refresh" Click="Refresh_Click" Margin="0,0,8,0"/>
                <Button Style="{StaticResource Btn}" Content="Disable Selected" Click="Disable_Click" Margin="0,0,8,0"/>
                <Button Style="{StaticResource BtnDanger}" Content="Delete Selected" Click="Delete_Click" Margin="0,0,8,0"/>
                <TextBlock x:Name="CountLabel" Text="—" Foreground="{DynamicResource Fg3}" FontFamily="{StaticResource FontMono}" FontSize="11" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" x:Name="TasksGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg2}"
                      RowBackground="{DynamicResource Bg}" AlternatingRowBackground="{DynamicResource Bg2}"
                      BorderBrush="{DynamicResource Line}" GridLinesVisibility="None"
                      HeadersVisibility="Column" SelectionMode="Extended" Margin="22,16">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Susp" Binding="{Binding SuspMarker}" Width="40"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="Task Path" Binding="{Binding TaskPath}" Width="*"/>
                    <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Style="{StaticResource DetailPaneBorder}" Margin="0,16,22,16">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="16,14,16,12">
                        <StackPanel>
                            <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,0,0,6" Text="DETAIL"/>
                            <TextBlock x:Name="DetailPath" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg3}" TextWrapping="Wrap" Text="—"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Padding="16,14" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,0,0,4" Text="TASK RUN"/>
                            <TextBlock x:Name="DetailTaskRun" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg2}" TextWrapping="Wrap" Margin="0,0,0,12" Text="—"/>
                            <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,0,0,4" Text="SUSPICION"/>
                            <TextBlock x:Name="DetailSusp" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Amber}" TextWrapping="Wrap" Text="—"/>
                            <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,12,0,4" Text="LAST RUN"/>
                            <TextBlock x:Name="DetailLastRun" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg2}" Text="—"/>
                            <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,12,0,4" Text="LAST RESULT"/>
                            <TextBlock x:Name="DetailLastResult" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg2}" Text="—"/>
                            <TextBlock Style="{StaticResource PanelSectionTitle}" Margin="0,12,0,4" Text="NEXT RUN"/>
                            <TextBlock x:Name="DetailNextRun" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{DynamicResource Fg2}" Text="—"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

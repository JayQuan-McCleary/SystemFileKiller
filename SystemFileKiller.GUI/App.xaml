<Application x:Class="SystemFileKiller.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SystemFileKiller.GUI"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ── Fonts ── -->
        <FontFamily x:Key="FontUi">Inter, Segoe UI, sans-serif</FontFamily>
        <FontFamily x:Key="FontMono">JetBrains Mono, Consolas, Courier New, monospace</FontFamily>

        <!-- ── Color tokens (Dark — default) ──
             These are SolidColorBrush instances. The app code-behind overwrites
             their .Color values at runtime when surface or accent changes. -->
        <SolidColorBrush x:Key="Bg"      Color="#0A0C10"/>
        <SolidColorBrush x:Key="Bg2"     Color="#0E1116"/>
        <SolidColorBrush x:Key="Panel"   Color="#13161C"/>
        <SolidColorBrush x:Key="Panel2"  Color="#181C24"/>
        <SolidColorBrush x:Key="Line"    Color="#232934"/>
        <SolidColorBrush x:Key="Line2"   Color="#2C3340"/>

        <SolidColorBrush x:Key="Fg"      Color="#E6E9EF"/>
        <SolidColorBrush x:Key="Fg2"     Color="#B6BCC8"/>
        <SolidColorBrush x:Key="Fg3"     Color="#7D8492"/>
        <SolidColorBrush x:Key="Fg4"     Color="#535A68"/>

        <!-- Signal colors. `Accent` is the swappable one (red/amber/blue/green). -->
        <SolidColorBrush x:Key="Accent"     Color="#DA4339"/>
        <SolidColorBrush x:Key="Accent2"    Color="#FA5C4D"/>
        <SolidColorBrush x:Key="AccentDim"  Color="#7C2A23"/>
        <SolidColorBrush x:Key="AccentGlow" Color="#2EDA4339"/>

        <SolidColorBrush x:Key="Green"   Color="#5DD2A1"/>
        <SolidColorBrush x:Key="Amber"   Color="#EAB95C"/>
        <SolidColorBrush x:Key="Blue"    Color="#6FAEDA"/>
        <SolidColorBrush x:Key="Violet"  Color="#A88AD9"/>

        <!-- Title bar specific (slightly darker than bg in dark mode) -->
        <SolidColorBrush x:Key="TitleBg" Color="#07090D"/>
        <SolidColorBrush x:Key="RailBg"  Color="#07090D"/>
        <SolidColorBrush x:Key="ConsoleBg" Color="#04060A"/>

        <!-- Selected row tint -->
        <SolidColorBrush x:Key="SelectedRowBg" Color="#332014" Opacity="0.55"/>

        <!-- ── Base text styles ── -->
        <Style TargetType="TextBlock" x:Key="MonoText">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="UiText">
            <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="DimMonoSmall">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg4}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="EyebrowText">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg4}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ScreenTitle">
            <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="PanelSectionTitle">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg4}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <!-- Implicit base for all TextBlocks so Foreground defaults to Fg -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ── Buttons ── -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource Panel}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Btn" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Foreground" Value="{DynamicResource Accent2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentDim}"/>
            <Setter Property="Background" Value="{DynamicResource AccentGlow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="B" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="{DynamicResource Fg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Bg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Fg}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Title-bar window button (icon only, square) -->
        <Style x:Key="TitlebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg3}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource Panel}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitlebarBtnClose" TargetType="Button" BasedOn="{StaticResource TitlebarBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Inputs ── -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Accent}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="B"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="B" Property="BorderBrush" Value="{DynamicResource Fg3}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Fg3}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
        </Style>

        <!-- ── Pills / Badges ── -->
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="7,2"/>
        </Style>
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Bg2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BadgeText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg3}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <!-- ── DataGrid ── -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg2}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1A1E26"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="Transparent"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
            <Setter Property="RowHeight" Value="28"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Bg2}"/>
            <Setter Property="Foreground" Value="{DynamicResource Fg3}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#1A1E26"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Panel}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectedRowBg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource Fg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ScrollBar (compact, sharp) ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
        </Style>

        <!-- ── Reusable border styles ── -->
        <Style x:Key="ScreenHeadBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Bg2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="22,16,22,14"/>
        </Style>
        <Style x:Key="ToolbarBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Bg2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
        <Style x:Key="StatStripBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Bg2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="0,1"/>
        </Style>
        <Style x:Key="DetailPaneBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Bg2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1,0,0,0"/>
        </Style>
        <Style x:Key="ConsoleBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ConsoleBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

    </Application.Resources>
</Application>
